# Frontend (Vite) environment. All VITE_* values are PUBLIC — they are inlined
# into the built JS and shipped to the browser. NEVER put the Alpha Vantage key
# (or any secret) here; it lives only on the backend.

# Base URL of the backend API.
#   - Leave EMPTY in development: the Vite dev server proxies /api to the backend
#     (same-origin), so no value is needed.
#   - In production set it to the API host, e.g. https://api.example.com
#     (no trailing slash required; one is stripped automatically).
VITE_API_BASE_URL=

# Client-side request timeout in milliseconds (positive number). Optional;
# defaults to 10000 (10s) when unset or invalid.
VITE_API_TIMEOUT_MS=10000
