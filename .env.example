# Application environment: development | test | production
NODE_ENV=development

# Port the backend listens on
PORT=3001

# Number of reverse-proxy hops to trust for client IP resolution.
# 0 (default) trusts none: req.ip is the direct socket address and any
# X-Forwarded-For header is ignored. Set to the number of proxies in front of
# this server (e.g. 1 behind a single load balancer) so per-client rate
# limiting works correctly. Never set this higher than your real proxy depth,
# or clients could spoof X-Forwarded-For to evade limits.
TRUST_PROXY=0

# Comma-separated list of additional allowed CORS origins ("*" is not allowed).
# http://localhost:5173 is always allowed OUTSIDE production. REQUIRED when
# NODE_ENV=production (an empty list there fails startup), since the SPA is served
# from a different origin and the dev fallback origin is not added in production.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=

# ---- Data source -----------------------------------------------------------
# Where stock data comes from: live | mock | historical | hybrid
#   mock       = deterministic in-process fixtures. NO Alpha Vantage traffic, no
#                API key and no database. Charts, SMA20/50, RSI and analysis all
#                work offline.
#   live       = real Alpha Vantage calls (requires ALPHA_VANTAGE_API_KEY).
#   historical = serve ONLY from the SQLite history store. NO external traffic;
#                data must be loaded first via `npm run data:import`.
#   hybrid     = SQLite first, supplemented from Alpha Vantage only when stale,
#                and falling back to stored data on a provider failure (needs a key
#                to actually sync; without one it just serves SQLite).
# When unset the default is `live` (safe: an unset value never silently serves
# fake data). `mock` is rejected at startup when NODE_ENV=production. historical/
# hybrid require Node >= 22.5 (the built-in node:sqlite module).

# 開発中にAlpha Vantageの利用枠を消費しない場合（推奨）
STOCK_DATA_MODE=mock

# 実API確認時のみ:
# STOCK_DATA_MODE=live
# ALPHA_VANTAGE_API_KEY=your_api_key_here

# Alpha Vantage API key. Used ONLY in live mode (in mock mode it is ignored). In
# live mode the app still boots without it, but stock requests then return 503
# API_KEY_MISSING. The key is read ONLY on the backend and is never sent to the
# frontend. Get a free key at:
#   https://www.alphavantage.co/support/#api-key
# Never commit your real key.
ALPHA_VANTAGE_API_KEY=

# Outbound request timeout (ms) for Alpha Vantage calls (1000–30000).
ALPHA_VANTAGE_TIMEOUT_MS=8000

# Hard cap on accepted daily data points from the provider. `outputsize=compact`
# returns ~100 points; 120 leaves headroom. A larger response is rejected
# (PROVIDER_RESPONSE_INVALID), never silently truncated. Positive integer.
ALPHA_VANTAGE_MAX_POINTS=120

# In-memory stock report cache (cleared on backend restart). Bounds memory (LRU
# eviction) and shields the provider's free-tier quota. It stores only the
# normalized, successful StockReport — never the API key or raw provider bodies.
# Maximum number of cached (ticker:range) reports (positive integer).
STOCK_CACHE_MAX_ENTRIES=100
# Cache entry lifetime in SECONDS (1–86400). Daily bars change only after the
# close, so a multi-hour TTL is safe. Default 21600 = 6 hours; max 86400 = 24h.
STOCK_CACHE_TTL_SECONDS=21600

# Persistent (disk) report cache directory — the SECOND cache layer, surviving
# restarts. Stores ONLY validated public StockReports (never the API key or raw
# provider bodies), keyed by ticker:range with a TTL + schema version. Relative
# paths resolve from the process CWD; point this at a writable, persistent volume
# in production. A write failure degrades to memory-only (never a request error).
# The directory is git-ignored (see .gitignore: .cache/).
STOCK_CACHE_DIR=.cache/stock-reports

# ---- Historical data pipeline (Phase 12–15) --------------------------------
# Used by the historical/hybrid modes and the data CLIs. These require Node >= 22.5
# (the built-in node:sqlite module). mock/live ignore everything below.

# Filesystem path to the SQLite history database — the SOURCE OF TRUTH for daily
# bars. Relative paths resolve from the process CWD. The default lives under the
# git-ignored .cache/ directory; the DB plus its -wal/-shm sidecars are git-ignored.
# The parent directory is created on demand. NEVER commit a real database file.
STOCK_DB_PATH=.cache/stock-data/history.sqlite

# Directory the daily job scans for *.csv files to import (optional). Empty = skip
# the CSV step. NEVER point this at a directory of secrets; only price CSVs.
STOCK_CSV_DIRECTORY=

# Comma-separated tickers the daily job syncs by default (optional). Example:
# STOCK_SYNC_TICKERS=AAPL,MSFT,NVDA
STOCK_SYNC_TICKERS=

# Hours after the newest stored bar before data is flagged "stale" for the UI and
# a same-day re-sync is allowed (1–168). Default 24h (one trading day).
STOCK_STALE_AFTER_HOURS=24

# Hard caps for a single CSV import — bound the work on a hostile/huge file.
# Max DATA rows (positive integer) and max file bytes (positive integer).
STOCK_IMPORT_MAX_ROWS=100000
STOCK_IMPORT_MAX_BYTES=5000000

# Seconds before a held daily-job lock is considered stale and reclaimable, so an
# abnormally-terminated run never leaves a permanent lock (60–86400). Default 1h.
STOCK_DAILY_LOCK_TIMEOUT_SECONDS=3600

# --- Backup / restore (Phase 21; data:backup / data:restore) ----------------
# Directory for SQLite backup snapshots. Relative paths resolve from the process
# CWD; point this at a PERSISTENT, off-host volume in production. Git-ignored.
STOCK_BACKUP_DIR=.cache/stock-data/backups
# How many generational snapshots to retain (newest wins). 1–365. Default 7.
STOCK_BACKUP_KEEP=7
